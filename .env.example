# TinyAnim — environment configuration
# Copy to .env and fill in. None are required for local dev (sensible
# defaults kick in: SQLite DB + dev-mode magic links printed to the screen).

# --- core ---
TINYANIM_ENV=development
# Stable secret for signing cookies/tokens. REQUIRED in production.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
TINYANIM_SECRET_KEY=
# Public base URL (used to build magic links & Stripe redirects).
TINYANIM_BASE_URL=http://127.0.0.1:8000
# Set true behind HTTPS so the session cookie is Secure.
TINYANIM_COOKIE_SECURE=false

# --- database ---
# Local dev defaults to SQLite. In production set a Postgres URL.
# DATABASE_URL=postgresql://user:pass@host:5432/tinyanim

# --- email (magic links) ---
# Without RESEND_API_KEY, the app runs in "dev email" mode and shows the
# sign-in link on screen instead of emailing it. Get a key at resend.com.
RESEND_API_KEY=
TINYANIM_EMAIL_FROM=TinyAnim <onboarding@resend.dev>

# --- billing (Stripe, test mode first) ---
# From the Stripe dashboard (toggle "Test mode"): Developers → API keys.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Create a recurring Price (or run scripts/stripe_bootstrap.py) and paste its id.
STRIPE_PRICE_ID=price_...
# From the webhook endpoint you create (stripe listen / dashboard).
STRIPE_WEBHOOK_SECRET=whsec_...
